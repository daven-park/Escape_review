# ─────────────────────────────────────────────────────────────────────────────
# apps/api/.env.example
# 이 파일을 복사해서 .env 로 만들고, 값을 직접 채워 넣으세요.
#   cp apps/api/.env.example apps/api/.env
#
# ⚠️  .env 파일은 절대 git에 커밋하지 마세요.
# ⚠️  각 값의 발급 방법은 docs/setup.md 를 참고하세요.
# ─────────────────────────────────────────────────────────────────────────────

# ── 앱 환경 ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# 형식: postgresql://유저:비밀번호@호스트:포트/DB이름
DATABASE_URL=postgresql://postgres:password@localhost:5432/escape_review

# 테스트 전용 DB (e2e 테스트 시 사용)
DATABASE_URL_TEST=postgresql://postgres:password@localhost:5432/escape_review_test

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# 최소 32자 이상의 랜덤 문자열 권장
# 생성 방법: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_FROM_JWT_SECRET

# Access Token 만료 (예: 1h, 15m)
JWT_ACCESS_EXPIRES_IN=1h
# Refresh Token 만료 (예: 30d)
JWT_REFRESH_EXPIRES_IN=30d
# bcrypt salt rounds (권장: 10~12)
BCRYPT_SALT_ROUNDS=12

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────────
# 발급: https://console.cloud.google.com → API 및 서비스 → 사용자 인증 정보
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# 개발 환경 콜백 URL (Google Cloud Console 승인된 리디렉션 URI에 등록 필요)
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ── Cloudflare R2 (이미지 스토리지) ──────────────────────────────────────────
# 발급: https://dash.cloudflare.com → R2 → 버킷 생성 → API 토큰
R2_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_BUCKET_NAME=escape-review-images

# R2 버킷 공개 URL (커스텀 도메인 또는 r2.dev 주소)
R2_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.r2.dev

# Presigned URL 만료 시간 (초)
R2_PRESIGN_EXPIRES=300

# ── 앱 URL (CORS 허용 대상) ───────────────────────────────────────────────────
WEB_URL=http://localhost:3001
MOBILE_DEEP_LINK=escapeapp://

# ── 이메일 (비밀번호 재설정용, 선택사항) ─────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=YOUR_APP_PASSWORD
# SMTP_FROM=noreply@escape-review.com
