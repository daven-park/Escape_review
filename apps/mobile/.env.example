# ─────────────────────────────────────────────────────────────────────────────
# apps/mobile/.env.example
# 이 파일을 복사해서 .env 로 만드세요.
#   cp apps/mobile/.env.example apps/mobile/.env
#
# ⚠️  EXPO_PUBLIC_ 접두어가 붙은 값은 앱 번들에 포함되어 사용자가 볼 수 있습니다.
#     Secret 값은 절대 EXPO_PUBLIC_ 으로 선언하지 마세요.
# ─────────────────────────────────────────────────────────────────────────────

# ── API 서버 주소 ─────────────────────────────────────────────────────────────
# 실기기 테스트 시 localhost 대신 실제 IP 사용 (예: http://192.168.0.10:3000/api/v1)
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# ── Google OAuth (Expo용) ─────────────────────────────────────────────────────
# 발급: https://console.cloud.google.com → OAuth 2.0 클라이언트 → iOS/Android 항목
# iOS 번들 ID와 Android 패키지 명에 맞는 클라이언트 ID를 각각 발급받아야 합니다.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_IOS_GOOGLE_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=YOUR_ANDROID_GOOGLE_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_WEB_GOOGLE_CLIENT_ID.apps.googleusercontent.com
